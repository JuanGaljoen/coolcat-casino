---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/slots', label: 'Slot Reviews' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-white text-gray-900">

    <!-- Responsible gambling top bar -->
    <div class="bg-gray-900 text-gray-400 text-xs py-1.5 text-center">
      18+ only &bull; Please gamble responsibly &bull;
      <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="underline underline-offset-2 hover:text-white transition-colors">BeGambleAware.org</a>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-gray-100 shadow-sm sticky top-0 z-50">
      <div class="mx-auto max-w-[1100px] px-4 sm:px-6 flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group" aria-label="CoolCat home">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="7" fill="var(--color-accent)"/>
            <!-- ears -->
            <polygon points="5,12 5,5 11,9" fill="white" opacity="0.9"/>
            <polygon points="23,12 23,5 17,9" fill="white" opacity="0.9"/>
            <!-- face -->
            <circle cx="14" cy="15" r="7" fill="white" opacity="0.95"/>
            <!-- eyes -->
            <ellipse cx="11.5" cy="14" rx="1.2" ry="1.5" fill="var(--color-accent)"/>
            <ellipse cx="16.5" cy="14" rx="1.2" ry="1.5" fill="var(--color-accent)"/>
            <!-- nose -->
            <polygon points="14,16.2 13,17.2 15,17.2" fill="var(--color-accent)" opacity="0.7"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-[15px] font-bold tracking-tight text-gray-900">CoolCat</span>
            <span class="text-[11px] font-medium text-gray-400 hidden sm:block mt-0.5">Casino Reviews</span>
          </div>
        </a>

        <!-- Nav links + CTA -->
        <div class="flex items-center gap-6">
          <nav aria-label="Main navigation">
            <ul class="flex items-center gap-6 text-sm font-medium">
              {navLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class={`transition-colors ${currentPath.startsWith(href) ? 'font-semibold' : 'text-gray-500 hover:text-gray-900'}`}
                    style={currentPath.startsWith(href) ? 'color: var(--color-accent);' : ''}
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          <a
            href="/slots"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-white px-4 py-2 rounded-lg transition-opacity hover:opacity-90"
            style="background: var(--color-accent);"
          >
            Top Picks
          </a>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="mx-auto max-w-[740px] px-4 sm:px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-20">
      <div class="mx-auto max-w-[1100px] px-4 sm:px-6 py-12">
        <div class="flex flex-col sm:flex-row justify-between gap-8">
          <div class="max-w-sm">
            <p class="text-white font-semibold mb-2" style="color: var(--color-accent);">CoolCat Casino Reviews</p>
            <p class="text-sm leading-relaxed">
              Independent slot machine reviews with verified RTP data. We never accept payment for positive reviews.
            </p>
          </div>
          <div class="text-sm">
            <p class="text-white font-medium mb-3">Quick Links</p>
            <ul class="space-y-2">
              <li><a href="/slots" class="hover:text-white transition-colors">Slot Reviews</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 text-xs text-gray-500 space-y-2">
          <p>
            This site contains affiliate links. We may earn a commission at no extra cost to you.
            Content is intended for adults 18+.
          </p>
          <p>&copy; {new Date().getFullYear()} CoolCat Casino Reviews. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
