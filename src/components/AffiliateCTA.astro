---
interface Props {
  affiliateUrl: string;
  slotName: string;
}

const { affiliateUrl, slotName } = Astro.props;
---

<div class="rounded-lg border border-gray-200 p-5 space-y-3">
  <p class="text-xs text-gray-500">
    This page contains affiliate links. We may earn a commission at no extra cost to you.
  </p>
  <a
    href={affiliateUrl}
    rel="nofollow noopener sponsored"
    target="_blank"
    class="block w-full rounded-md px-5 py-3 text-center text-sm font-semibold text-white transition-opacity hover:opacity-90"
    style="background-color: var(--color-accent);"
  >
    Play {slotName} Now
  </a>
</div>
