---
import { VOLATILITY_LABELS } from '../types';
import type { Volatility } from '../types';

interface Props {
  volatility: Volatility;
}

const { volatility } = Astro.props;

const styles: Record<Volatility, string> = {
  low:        'bg-green-100 text-green-800',
  medium:     'bg-amber-100 text-amber-800',
  high:       'bg-orange-100 text-orange-800',
  'very-high': 'bg-red-100 text-red-800',
};
---

<span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${styles[volatility]}`}>
  {VOLATILITY_LABELS[volatility]}
</span>
