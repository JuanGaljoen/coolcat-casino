---
interface Props {
  rating: number; // 0–5, one decimal
}

const { rating } = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---

<span class="inline-flex items-center gap-0.5" aria-label={`Rating: ${rating} out of 5`}>
  {Array.from({ length: fullStars }).map(() => (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" aria-hidden="true">
      <path fill="var(--color-accent)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  ))}

  {hasHalf && (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" aria-hidden="true">
      <defs>
        <linearGradient id="half">
          <stop offset="50%" stop-color="var(--color-accent)" />
          <stop offset="50%" stop-color="#d1d5db" />
        </linearGradient>
      </defs>
      <path fill="url(#half)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  )}

  {Array.from({ length: emptyStars }).map(() => (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" aria-hidden="true">
      <path fill="#d1d5db" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  ))}
</span>
