---
const reviewers = [
  {
    name: 'Felix Spinclaw',
    title: 'Senior Slots Analyst',
    specialty: 'High-volatility & jackpot slots',
    bio: 'Felix has spent 8 years hunting max wins on high-variance games. If there\'s a hidden mechanic, he\'s found it.',
    avatar: '🐱',
    color: '#E5622A',
  },
  {
    name: 'Mittens von Reels',
    title: 'RTP Specialist',
    specialty: 'Payout analysis & maths models',
    bio: 'Mittens doesn\'t trust a single RTP claim without verifying it herself. 10,000 spin samples minimum.',
    avatar: '😸',
    color: '#0ea5e9',
  },
  {
    name: 'Whiskers McGamble',
    title: 'Bonus Feature Expert',
    specialty: 'Free spins, multipliers & buy-ins',
    bio: 'Whiskers has triggered more free spins rounds than anyone alive. He reviews every bonus mode in detail.',
    avatar: '🐈',
    color: '#8b5cf6',
  },
  {
    name: 'Chairman Meow',
    title: 'Editor in Chief',
    specialty: 'Editorial standards & final verdicts',
    bio: 'The Chairman sets the bar. Every review that goes live has earned his seal of approval.',
    avatar: '🐾',
    color: '#10b981',
  },
] as const;
---

<section class="mt-20">
  <div class="mb-8">
    <h2 class="text-2xl font-semibold">Meet the Reviewers</h2>
    <p class="mt-2 text-gray-500 text-sm max-w-xl">
      Every review on CoolCat is written by one of our specialist analysts. No AI-generated verdicts, no sponsored scores.
    </p>
  </div>

  <div class="-mx-4 sm:-mx-6">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {reviewers.map((reviewer) => (
          <div class="rounded-xl border border-gray-200 bg-white p-5 flex flex-col gap-3">
            <!-- Avatar -->
            <div
              class="w-14 h-14 rounded-full flex items-center justify-center text-2xl shrink-0"
              style={`background-color: ${reviewer.color}1a;`}
            >
              {reviewer.avatar}
            </div>

            <!-- Name + title -->
            <div>
              <p class="font-semibold text-gray-900 leading-tight">{reviewer.name}</p>
              <p class="text-xs font-medium mt-0.5" style={`color: ${reviewer.color};`}>{reviewer.title}</p>
            </div>

            <!-- Specialty -->
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide border-t border-gray-100 pt-3">
              {reviewer.specialty}
            </p>

            <!-- Bio -->
            <p class="text-sm text-gray-600 leading-relaxed">{reviewer.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
