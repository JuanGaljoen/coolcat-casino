---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlotCard from '../../components/SlotCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import { getAllSlots } from '../../lib/sanity';

const slots = await getAllSlots();

const now = new Date();
const year = now.getFullYear();
const month = now.toLocaleString('en-GB', { month: 'long' });

const title = `Online Slot Reviews (${year}) — RTP, Ratings & Expert Analysis | CoolCat`;
const description = `Expert slot machine reviews with verified RTP, volatility ratings and bonus feature breakdowns. Updated ${month} ${year}.`;
---

<BaseLayout {title} {description} canonical={new URL('/slots', Astro.site).href}>
  <div class="space-y-12">
    <header>
      <h1 class="text-3xl font-semibold">Slot Machine Reviews</h1>
      <p class="mt-2 text-gray-500 text-sm">
        {slots.length} review{slots.length !== 1 ? 's' : ''} — updated {month} {year}
      </p>
    </header>

    {slots.length > 0 ? (
      <>
        <!-- Card grid — break out to 1100px -->
        <div class="-mx-4 sm:-mx-6">
          <div class="mx-auto max-w-[1100px] px-4 sm:px-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {slots.map((slot) => (
                <SlotCard review={slot} />
              ))}
            </div>
          </div>
        </div>

        <!-- Comparison table -->
        <section>
          <h2 class="text-xl font-semibold mb-4">Compare All Slots</h2>
          <div class="-mx-4 sm:-mx-6">
            <div class="mx-auto max-w-[1100px] px-4 sm:px-6">
              <ComparisonTable slots={slots} />
            </div>
          </div>
        </section>
      </>
    ) : (
      <p class="text-gray-500">No reviews published yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>
