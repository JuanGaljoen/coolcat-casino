---
import { Image } from 'astro:assets';
import { toHTML } from '@portabletext/to-html';
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import AffiliateCTA from '../../components/AffiliateCTA.astro';
import QuickStatsTable from '../../components/QuickStatsTable.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getSlugs, getSlotBySlug } from '../../lib/sanity';
import { urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getSlugs();
  return slugs.map(({ slug }) => ({ params: { slug: slug.current } }));
}

const { slug } = Astro.params;
const review = await getSlotBySlug(slug);

if (!review) return Astro.redirect('/404');

const year = new Date().getFullYear();

const updatedAt = new Date(review.updatedAt).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const heroImageUrl = urlFor(review.heroImage.asset).width(1200).height(630).fit('crop').url();
const ogImageUrl   = urlFor(review.heroImage.asset).width(1200).height(630).fit('crop').url();

const volatilityLabel: Record<string, string> = {
  low: 'Low',
  medium: 'Medium',
  high: 'High',
  'very-high': 'Very High',
};

const pageTitle    = `${review.title} Review (${year}) — RTP ${review.rtp.toFixed(2)}%, ${volatilityLabel[review.volatility]} Volatility | CoolCat`;
const canonicalUrl = new URL(`/slots/${slug}`, Astro.site).href;

const bodyHtml = toHTML(review.body as Parameters<typeof toHTML>[0]);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: `${review.title} Review`,
  reviewBody: review.verdict,
  dateModified: review.updatedAt,
  author: { '@type': 'Organization', name: 'CoolCat Casino Reviews' },
  itemReviewed: {
    '@type': 'Product',
    name: review.title,
    description: `${review.provider} slot — RTP ${review.rtp.toFixed(2)}%`,
    brand: { '@type': 'Brand', name: review.provider },
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: review.rating,
    bestRating: 5,
    worstRating: 1,
  },
};
---

<ReviewLayout
  title={pageTitle}
  description={review.verdict}
  canonical={canonicalUrl}
  ogImage={ogImageUrl}
  jsonLd={jsonLd}
>

  <!-- ── Main content column ── -->

  <h1 class="text-3xl font-semibold leading-tight mb-4">
    {review.title} Review ({year})
  </h1>

  <div class="flex items-center gap-3 mb-6">
    <RatingStars rating={review.rating} />
    <span class="text-sm text-gray-500">{review.rating.toFixed(1)} / 5</span>
  </div>

  <!-- Hero image -->
  <Image
    src={heroImageUrl}
    alt={review.heroImage.alt ?? review.title}
    width={1200}
    height={630}
    class="w-full rounded-lg mb-6 object-cover"
  />

  <!-- Affiliate CTA (above fold) -->
  <AffiliateCTA affiliateUrl={review.affiliateUrl} slotName={review.title} />

  <!-- Pros & Cons -->
  {(review.pros?.length > 0 || review.cons?.length > 0) && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-8">
      <!-- Pros -->
      <div class="rounded-lg border border-green-200 bg-green-50 p-4">
        <h2 class="text-sm font-semibold text-green-800 mb-3">Pros</h2>
        <ul class="space-y-2">
          {review.pros.map((pro) => (
            <li class="flex items-start gap-2 text-sm text-green-900">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {pro}
            </li>
          ))}
        </ul>
      </div>

      <!-- Cons -->
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <h2 class="text-sm font-semibold text-red-800 mb-3">Cons</h2>
        <ul class="space-y-2">
          {review.cons.map((con) => (
            <li class="flex items-start gap-2 text-sm text-red-900">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>
  )}

  <!-- Portable Text body -->
  <div class="prose prose-gray max-w-none mt-8" set:html={bodyHtml} />

  <!-- Last updated -->
  <p class="mt-8 text-xs text-gray-400">Last updated: {updatedAt}</p>

  <!-- ── Sidebar ── -->
  <div slot="sidebar" class="space-y-6 lg:sticky lg:top-6">
    <div>
      <h2 class="text-sm font-semibold text-gray-700 mb-3">Quick Stats</h2>
      <QuickStatsTable review={review} />
    </div>
    <AffiliateCTA affiliateUrl={review.affiliateUrl} slotName={review.title} />
  </div>

</ReviewLayout>
