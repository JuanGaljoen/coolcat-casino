---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlotCard from '../components/SlotCard.astro';
import TeamSection from '../components/TeamSection.astro';
import { getFeaturedSlots } from '../lib/sanity';

const featured = await getFeaturedSlots(6);
---

<BaseLayout
  title="CoolCat — Expert Slot Machine Reviews with Verified RTP"
  description="Independent slot machine reviews with real RTP data, volatility ratings, and bonus feature analysis. No fluff, just facts."
  canonical={new URL('/', Astro.site).href}
>

  <!-- Hero -->
  <section class="relative -mx-4 sm:-mx-6 mb-14" style="background-color: var(--color-accent-light);">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 py-16 sm:py-20">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">
          Independent · Verified · No fluff
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight tracking-tight text-gray-900">
          Honest Slot Reviews,<br />Verified RTP
        </h1>
        <p class="mt-5 text-lg text-gray-600 leading-relaxed max-w-xl">
          Our analysts play every slot and verify RTP figures before publishing. Real data, no sponsored rankings.
        </p>
        <a
          href="/slots"
          class="inline-block mt-7 px-6 py-3 rounded-lg text-white font-semibold text-sm transition-opacity hover:opacity-90"
          style="background-color: var(--color-accent);"
        >
          Browse All Reviews →
        </a>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="-mx-4 sm:-mx-6 mb-14">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6">
      <div class="grid grid-cols-3 gap-4 border border-gray-200 rounded-xl divide-x divide-gray-200 bg-white">
        {[
          { stat: '50+', label: 'Slots reviewed' },
          { stat: '4', label: 'Expert analysts' },
          { stat: '100%', label: 'Independent verdicts' },
        ].map(({ stat, label }) => (
          <div class="px-6 py-5 text-center">
            <p class="text-2xl font-bold" style="color: var(--color-accent);">{stat}</p>
            <p class="text-xs text-gray-500 mt-1 font-medium">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Top Rated Slots -->
  <section>
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-2xl font-semibold">Top Rated Slots</h2>
      <a
        href="/slots"
        class="text-sm font-medium transition-colors hover:opacity-75"
        style="color: var(--color-accent);"
      >
        View all →
      </a>
    </div>

    <div class="-mx-4 sm:-mx-6">
      <div class="mx-auto max-w-[1100px] px-4 sm:px-6">
        {featured.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {featured.map((review) => (
              <SlotCard review={review} />
            ))}
          </div>
        ) : (
          <p class="text-gray-500">No featured reviews yet.</p>
        )}
      </div>
    </div>
  </section>

  <!-- Meet the team -->
  <TeamSection />

</BaseLayout>
